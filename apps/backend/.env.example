# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/ecosmart_db

# ── JWT ───────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ganti_dengan_string_random_64_karakter_yang_sangat_panjang
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:8081

# ── InfluxDB ──────────────────────────────────────────────────
# Setelah jalankan docker compose, buka http://localhost:8086
# Setup: buat org "ecosmart", bucket "sensors", lalu copy token
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=ganti_dengan_token_dari_influxdb_ui
INFLUXDB_ORG=ecosmart
INFLUXDB_BUCKET=sensors

# ── MQTT ──────────────────────────────────────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=ecosmart-backend
MQTT_TOPIC_PREFIX=ecosmart
